{
  "name": "modbus-lab",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:client",
    "build": "npm run build:client && npm run build:server",
    "check": "npm run check:client && npm run check:server",
    "dev:client": "npm run dev --workspace @modbus-lab/client",
    "build:client": "npm run build --workspace @modbus-lab/client",
    "check:client": "npm run check --workspace @modbus-lab/client",
    "tauri:client": "npm run tauri --workspace @modbus-lab/client",
    "dev:server": "npm run dev --workspace @modbus-lab/server",
    "build:server": "npm run build --workspace @modbus-lab/server",
    "check:server": "npm run check --workspace @modbus-lab/server",
    "tauri:server": "npm run tauri --workspace @modbus-lab/server"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.5",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tslib": "^2.8.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
