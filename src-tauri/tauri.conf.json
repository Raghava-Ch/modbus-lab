{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "modbux",
  "version": "0.0.0",
  "identifier": "com.modbux.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "modbux",
        "width": 800,
        "height": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
