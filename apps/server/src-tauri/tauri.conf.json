{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ModbusLab Server",
  "version": "0.0.4",
  "identifier": "com.modbuslab.Server",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "ModbusLab Server",
        "width": 800,
        "height": 600,
        "visible": true,
        "center": true,
        "focus": true,
        "backgroundColor": "#121417"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
